      <aliases enabled='yes' />
      <column caption='Solar Light Usage Description' datatype='string' name='[Calculation_171418299633930240]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Solar Lights] = 1 THEN &quot;Yes, most family&quot;&#10;ELSEIF [Solar Lights] = 2 THEN &quot;Yes, small number of family&quot;&#10;ELSEIF [Solar Lights] = 3 THEN &quot;None&quot;&#10;ELSE &quot;Unknown&quot;&#10;END' />
      </column>
      <column caption='Lighting on the main village road' datatype='string' name='[Calculation_171418299634855937]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Village Road Light] = 1  THEN&#10;&quot;electricity operated by the government&quot;&#10;ELSEIF [Village Road Light] = 2 THEN&#10;&quot;Electricity operated by non-government&quot;&#10;ELSEIF [Village Road Light] = 3 THEN&#10;&quot;Non-electric&quot;&#10;ELSE&#10;    &quot;Unknown lighting&quot;&#10;END' />
      </column>
      <column caption='defecation facilities by most families in the village' datatype='string' name='[Calculation_171418299637723139]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Private Delivery] = 1 THEN&#10;    &quot;Private toilet&quot;&#10;ELSEIF [Private Delivery] = 2 THEN&#10;    &quot;Public toilet&quot;&#10;ELSEIF [Private Delivery] = 3 THEN&#10;    &quot;Shared toilets&quot;&#10;ELSEIF [Private Delivery] = 4 THEN&#10;    &quot;Non-latrines&quot;&#10;ELSE&#10;    &quot;Unknown&quot;&#10;END' />
      </column>
      <column caption='Liquid Waste Disposal:' datatype='string' name='[Calculation_171418299639590918]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Waste Water Channel] = 1 THEN&#10;    &quot;Infiltration holes&quot;&#10;ELSEIF [Waste Water Channel] = 2 THEN&#10;    &quot;Drainage (ditch)&quot;&#10;ELSEIF [Waste Water Channel] = 3 THEN&#10;    &quot;River/irrigation canal/lake/sea&quot;&#10;ELSEIF [Waste Water Channel] = 4 THEN&#10;    &quot;In holes or open ground&quot;&#10;ELSEIF [Waste Water Channel] = 5 THEN&#10;    &quot;Others&quot;&#10;ELSE&#10;    &quot;Unknown&quot;&#10;END' />
      </column>
      <column caption='The water source for most families to drink comes from' datatype='string' name='[Calculation_171418299640684551]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Drinking Source] = 1 THEN&#10;    &quot;Branded bottled water&quot;&#10;ELSEIF [Drinking Source] = 2 THEN&#10;    &quot;Refilled water&quot;&#10;ELSEIF [Drinking Source] = 3 THEN&#10;    &quot;Metered plumbing (PAM/PDAM)&quot;&#10;ELSEIF [Drinking Source] = 4 THEN&#10;    &quot;Unmetered plumbing&quot;&#10;ELSEIF [Drinking Source] = 5 THEN&#10;    &quot;Drilled well or pump&quot;&#10;ELSEIF [Drinking Source] = 6 THEN&#10;    &quot;Well&quot;&#10;ELSEIF [Drinking Source] = 7 THEN&#10;    &quot;Natural spring water&quot;&#10;ELSEIF [Drinking Source] = 8 THEN&#10;    &quot;River/lake/pond/reservoir/dam&quot;&#10;ELSEIF [Drinking Source] = 9 THEN&#10;    &quot;Rain water&quot;&#10;ELSE&#10;    &quot;Unknown&quot;&#10;END' />
      </column>
      <column caption='Bathing Water Source' datatype='string' name='[Calculation_171418299641503752]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Bathing Source] = 1 THEN&#10;    &quot;Metered plumbing (PAM/PDAM)&quot;&#10;ELSEIF [Bathing Source] = 2 THEN&#10;    &quot;Unmetered plumbing&quot;&#10;ELSEIF [Bathing Source] = 3 THEN&#10;    &quot;Drilled well or pump&quot;&#10;ELSEIF [Bathing Source] = 4 THEN&#10;    &quot;Well&quot;&#10;ELSEIF [Bathing Source] = 5 THEN&#10;    &quot;Natural spring water&quot;&#10;ELSEIF [Bathing Source] = 6 THEN&#10;    &quot;River/lake/pond/reservoir/dam&quot;&#10;ELSEIF [Bathing Source] = 7 THEN&#10;    &quot;Rain water&quot;&#10;ELSE&#10;    &quot;Unknown&quot;&#10;END' />
      </column>
      <column caption='Cellphone Usage Presence' datatype='string' name='[Calculation_171418299643834380]' role='dimension' type='nominal'>
